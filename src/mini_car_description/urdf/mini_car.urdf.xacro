<?xml version="1.0"?>

<robot name="mini_car" xmlns:xacro="http://www.ros.org/wiki/xacro">

  <!-- ========================= -->
  <!-- Parameters -->
  <!-- ========================= -->

  <xacro:property name="base_length" value="0.60"/>
  <xacro:property name="base_width" value="0.28"/>
  <xacro:property name="base_height" value="0.08"/>

  <!-- Distance from ground to bottom of chassis -->
  <xacro:property name="ground_clearance" value="0.035"/>

  <xacro:property name="wheel_radius" value="0.07"/>
  <xacro:property name="wheel_width" value="0.04"/>

  <xacro:property name="front_axle_x" value="0.20"/>
  <xacro:property name="rear_axle_x" value="-0.20"/>
  <xacro:property name="wheel_y" value="0.17"/>

  <xacro:property name="lidar_radius" value="0.045"/>
  <xacro:property name="lidar_height" value="0.04"/>

  <!-- Derived values -->
  <xacro:property
    name="base_center_z"
    value="${ground_clearance + base_height / 2.0}"/>

  <xacro:property
    name="wheel_joint_z"
    value="${wheel_radius - base_center_z}"/>

  <!-- ========================= -->
  <!-- Materials -->
  <!-- ========================= -->

  <material name="blue">
    <color rgba="0.1 0.3 0.9 1.0"/>
  </material>

  <material name="black">
    <color rgba="0.02 0.02 0.02 1.0"/>
  </material>

  <material name="red">
    <color rgba="0.9 0.1 0.1 1.0"/>
  </material>

  <material name="yellow">
    <color rgba="0.9 0.8 0.1 1.0"/>
  </material>

  <!-- ========================= -->
  <!-- Macros -->
  <!-- ========================= -->

  <xacro:macro name="wheel_link" params="name">
    <link name="${name}">
      <visual>
        <!-- Cylinder default axis is Z. Rotate it so the wheel axis is Y. -->
        <origin xyz="0 0 0" rpy="1.5708 0 0"/>
        <geometry>
          <cylinder radius="${wheel_radius}" length="${wheel_width}"/>
        </geometry>
        <material name="black"/>
      </visual>

      <collision>
        <origin xyz="0 0 0" rpy="1.5708 0 0"/>
        <geometry>
          <cylinder radius="${wheel_radius}" length="${wheel_width}"/>
        </geometry>
      </collision>

      <inertial>
        <origin xyz="0 0 0" rpy="0 0 0"/>
        <mass value="0.25"/>
        <inertia
          ixx="0.001"
          ixy="0.0"
          ixz="0.0"
          iyy="0.001"
          iyz="0.0"
          izz="0.001"/>
      </inertial>
    </link>
  </xacro:macro>

  <xacro:macro name="steering_link" params="name">
    <link name="${name}">
      <visual>
        <origin xyz="0 0 0" rpy="0 0 0"/>
        <geometry>
          <box size="0.045 0.045 0.045"/>
        </geometry>
        <material name="yellow"/>
      </visual>

      <collision>
        <origin xyz="0 0 0" rpy="0 0 0"/>
        <geometry>
          <box size="0.045 0.045 0.045"/>
        </geometry>
      </collision>

      <inertial>
        <origin xyz="0 0 0" rpy="0 0 0"/>
        <mass value="0.1"/>
        <inertia
          ixx="0.0001"
          ixy="0.0"
          ixz="0.0"
          iyy="0.0001"
          iyz="0.0"
          izz="0.0001"/>
      </inertial>
    </link>
  </xacro:macro>

  <!-- ========================= -->
  <!-- Base footprint -->
  <!-- base_footprint is on the ground plane. -->
  <!-- ========================= -->

  <link name="base_footprint"/>

  <joint name="base_footprint_joint" type="fixed">
    <parent link="base_footprint"/>
    <child link="base_link"/>
    <origin xyz="0 0 ${base_center_z}" rpy="0 0 0"/>
  </joint>

  <!-- ========================= -->
  <!-- Base link -->
  <!-- ========================= -->

  <link name="base_link">
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <box size="${base_length} ${base_width} ${base_height}"/>
      </geometry>
      <material name="blue"/>
    </visual>

    <collision>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <box size="${base_length} ${base_width} ${base_height}"/>
      </geometry>
    </collision>

    <inertial>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <mass value="3.0"/>
      <inertia
        ixx="0.04"
        ixy="0.0"
        ixz="0.0"
        iyy="0.08"
        iyz="0.0"
        izz="0.10"/>
    </inertial>
  </link>

  <!-- ========================= -->
  <!-- Front left steering + wheel -->
  <!-- ========================= -->

  <xacro:steering_link name="front_left_steering_link"/>
  <xacro:wheel_link name="front_left_wheel_link"/>

  <joint name="front_left_steering_joint" type="revolute">
    <parent link="base_link"/>
    <child link="front_left_steering_link"/>
    <origin xyz="${front_axle_x} ${wheel_y} ${wheel_joint_z}" rpy="0 0 0"/>
    <axis xyz="0 0 1"/>
    <limit lower="-0.6" upper="0.6" effort="10.0" velocity="1.0"/>
  </joint>

  <joint name="front_left_wheel_joint" type="continuous">
    <parent link="front_left_steering_link"/>
    <child link="front_left_wheel_link"/>
    <origin xyz="0 0 0" rpy="0 0 0"/>
    <axis xyz="0 1 0"/>
  </joint>

  <!-- ========================= -->
  <!-- Front right steering + wheel -->
  <!-- ========================= -->

  <xacro:steering_link name="front_right_steering_link"/>
  <xacro:wheel_link name="front_right_wheel_link"/>

  <joint name="front_right_steering_joint" type="revolute">
    <parent link="base_link"/>
    <child link="front_right_steering_link"/>
    <origin xyz="${front_axle_x} ${-wheel_y} ${wheel_joint_z}" rpy="0 0 0"/>
    <axis xyz="0 0 1"/>
    <limit lower="-0.6" upper="0.6" effort="10.0" velocity="1.0"/>
  </joint>

  <joint name="front_right_wheel_joint" type="continuous">
    <parent link="front_right_steering_link"/>
    <child link="front_right_wheel_link"/>
    <origin xyz="0 0 0" rpy="0 0 0"/>
    <axis xyz="0 1 0"/>
  </joint>

  <!-- ========================= -->
  <!-- Rear left wheel -->
  <!-- ========================= -->

  <xacro:wheel_link name="rear_left_wheel_link"/>

  <joint name="rear_left_wheel_joint" type="continuous">
    <parent link="base_link"/>
    <child link="rear_left_wheel_link"/>
    <origin xyz="${rear_axle_x} ${wheel_y} ${wheel_joint_z}" rpy="0 0 0"/>
    <axis xyz="0 1 0"/>
  </joint>

  <!-- ========================= -->
  <!-- Rear right wheel -->
  <!-- ========================= -->

  <xacro:wheel_link name="rear_right_wheel_link"/>

  <joint name="rear_right_wheel_joint" type="continuous">
    <parent link="base_link"/>
    <child link="rear_right_wheel_link"/>
    <origin xyz="${rear_axle_x} ${-wheel_y} ${wheel_joint_z}" rpy="0 0 0"/>
    <axis xyz="0 1 0"/>
  </joint>

  <!-- ========================= -->
  <!-- LiDAR placeholder -->
  <!-- The actual Gazebo LiDAR sensor will be added later. -->
  <!-- ========================= -->

  <link name="lidar_link">
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <cylinder radius="${lidar_radius}" length="${lidar_height}"/>
      </geometry>
      <material name="red"/>
    </visual>

    <collision>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <cylinder radius="${lidar_radius}" length="${lidar_height}"/>
      </geometry>
    </collision>

    <inertial>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <mass value="0.1"/>
      <inertia
        ixx="0.0001"
        ixy="0.0"
        ixz="0.0"
        iyy="0.0001"
        iyz="0.0"
        izz="0.0001"/>
    </inertial>
  </link>

  <joint name="lidar_joint" type="fixed">
    <parent link="base_link"/>
    <child link="lidar_link"/>
    <origin
      xyz="0.15 0 ${base_height / 2.0 + lidar_height / 2.0}"
      rpy="0 0 0"/>
  </joint>

</robot>